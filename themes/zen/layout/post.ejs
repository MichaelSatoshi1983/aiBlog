<%- partial('partial/head') %>
<body>
  <%- partial('partial/header') %>
  <main class="container">
    <article class="post">
      <header class="post-header">
        <h1><%= page.title %></h1>
        <div class="post-meta">
          <time datetime="<%= date_xml(page.date) %>"><%= date(page.date) %></time>
          <% if (page.tags && page.tags.length) { %>
          <span class="tags">
            <% page.tags.forEach(function(tag) { %>
            <a href="<%- url_for(tag.path) %>" class="tag">#<%= tag.name %></a>
            <% }) %>
          </span>
          <% } %>
        </div>
      </header>
      <div class="post-content">
        <%- page.content %>
      </div>
      <% if (theme.twikoo && theme.twikoo.enable) { %>
      <%- partial('components/twikoo') %>
      <% } %>
      <% if (theme.beaudar && theme.beaudar.enable) { %>
      <%- partial('components/beaudar') %>
      <% } %>
    </article>
  </main>
  <%- partial('partial/footer') %>
</body>
</html>
