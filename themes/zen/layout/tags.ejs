<%- partial('partial/head') %>
<body>
  <%- partial('partial/header') %>
  <main class="container">
    <h1>Tags</h1>
    <div class="tag-cloud">
      <% site.tags.each(function(tag) { %>
      <a href="<%- url_for(tag.path) %>" class="tag-item">
        <%= tag.name %> (<%= tag.posts.length %>)
      </a>
      <% }) %>
    </div>
  </main>
  <%- partial('partial/footer') %>
</body>
</html>
