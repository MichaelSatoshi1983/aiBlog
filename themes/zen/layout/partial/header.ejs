<header class="site-header">
  <div class="container">
    <a href="/" class="site-title"><%= config.title %></a>
    <nav class="site-nav">
      <% if (theme.menu) { %>
        <% for (var name in theme.menu) { %>
          <a href="<%- url_for(theme.menu[name]) %>"><%= name %></a>
        <% } %>
      <% } %>
      <button id="theme-toggle" aria-label="Toggle theme">🌓</button>
    </nav>
  </div>
</header>
